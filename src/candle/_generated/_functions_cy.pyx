    dot = _redispatch("sum", keyset,
        _redispatch("mul", keyset, dl_dxhat, x_hat), dim=axes, keepdim=True)
    return _redispatch("div", keyset,
        _redispatch("add", keyset, dl_dxhat,
            _redispatch("neg", keyset, _redispatch("mul", keyset, x_hat,
                _redispatch("div", keyset, dot, n_t)))),
        rms)


